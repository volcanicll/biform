{
  "name": "common-component",
  "version": "0.1.0",
  "description": "One-API-Two-UIs React form components (PC + Mobile)",
  "license": "MIT",
  "author": "volcanicll <1605090219@qq.com>",
  "homepage": "https://github.com/volcanicll/biform#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volcanicll/biform.git"
  },
  "bugs": {
    "url": "https://github.com/volcanicll/biform/issues"
  },
  "keywords": [
    "react",
    "react-components",
    "form",
    "ui-library",
    "platform",
    "responsive",
    "headless",
    "mobile",
    "pc",
    "accessibility",
    "a11y",
    "css-modules",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.less"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./input": {
      "types": "./dist/components/input/index.d.ts",
      "import": "./dist/components/input/index.js",
      "require": "./dist/components/input/index.cjs"
    },
    "./select": {
      "types": "./dist/components/select/index.d.ts",
      "import": "./dist/components/select/index.js",
      "require": "./dist/components/select/index.cjs"
    },
    "./switch": {
      "types": "./dist/components/switch/index.d.ts",
      "import": "./dist/components/switch/index.js",
      "require": "./dist/components/switch/index.cjs"
    },
    "./checkbox": {
      "types": "./dist/components/checkbox/index.d.ts",
      "import": "./dist/components/checkbox/index.js",
      "require": "./dist/components/checkbox/index.cjs"
    },
    "./form": {
      "types": "./dist/components/form/index.d.ts",
      "import": "./dist/components/form/index.js",
      "require": "./dist/components/form/index.cjs"
    },
    "./platform": {
      "types": "./dist/core/platform/index.d.ts",
      "import": "./dist/core/platform/index.js",
      "require": "./dist/core/platform/index.cjs"
    },
    "./theme.css": "./dist/radiant.css"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build",
    "build:storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src",
    "prepublishOnly": "yarn lint && yarn typecheck && yarn test && yarn build"
  },
  "peerDependencies": {
    "react": ">=17 || ^18",
    "react-dom": ">=17 || ^18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": false },
    "react-dom": { "optional": false }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.5.0",
    "less": "^4.6.7",
    "glob": "^11.0.0",
    "typescript": "^5.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^22.0.0",
    "storybook": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.0",
    "@storybook/addon-a11y": "^8.6.0",
    "vitest": "^2.1.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^25.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
